# URL pública usada para canonical, sitemap, Open Graph y datos estructurados
NEXT_PUBLIC_SITE_URL=https://scriptordigital.vercel.app

# Obligatoria para el formulario de contacto
RESEND_API_KEY=re_xxxxxxxxx

# Opcionales: notificación interna por WhatsApp mediante CallMeBot.
# El número debe incluir código de país, sin espacios (ejemplo Argentina: 54911xxxxxxxx).
# Nunca expongas estas variables con el prefijo NEXT_PUBLIC_.
WHATSAPP_PHONE_NUMBER=54911xxxxxxxx
WHATSAPP_API_KEY=xxxxxxxx
